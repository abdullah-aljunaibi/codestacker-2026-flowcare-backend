{
  "name": "flowcare-backend",
  "version": "1.0.0",
  "description": "FlowCare Queue & Appointment Booking System - Backend",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npx esbuild src/index.ts --bundle --platform=node --format=esm --outdir=dist --external:@prisma/client --external:bcrypt --external:cors --external:dotenv --external:express --external:jsonwebtoken --external:mime-types --external:multer --external:zod",
    "start": "node dist/index.js",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "test": "vitest",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@prisma/client": "^6.4.0",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "mime-types": "^3.0.2",
    "multer": "^2.1.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.19.15",
    "esbuild": "^0.27.3",
    "eslint": "^9.22.0",
    "prisma": "^6.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.9.3",
    "vitest": "^3.0.8"
  }
}
